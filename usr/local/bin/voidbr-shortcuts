#!/usr/bin/env python3
import gi
gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, Gdk

SHORTCUTS = [
    ("General", [
        ("Super + Enter", "Open terminal"),
        ("Super + D", "Application launcher"),
        ("Super + Shift + C", "Reload Sway configuration"),
        ("Super + Shift + R", "Restart Sway"),
        ("Super + Shift + E", "Exit Sway"),
        ("Super + Shift + Q", "Close focused window"),
        ("Super + L", "Lock screen"),
        ("Print", "Take screenshot"),
    ]),
    ("Focus", [
        ("Super + Left", "Focus left"),
        ("Super + Down", "Focus down"),
        ("Super + Up", "Focus up"),
        ("Super + Right", "Focus right"),
        ("Super + H", "Focus left"),
        ("Super + J", "Focus down"),
        ("Super + K", "Focus up"),
        ("Super + L", "Focus right"),
        ("Super + A", "Focus parent"),
        ("Super + Tab", "Focus previous window"),
    ]),
    ("Move Windows", [
        ("Super + Shift + Left", "Move window left"),
        ("Super + Shift + Down", "Move window down"),
        ("Super + Shift + Up", "Move window up"),
        ("Super + Shift + Right", "Move window right"),
        ("Super + Shift + H", "Move window left"),
        ("Super + Shift + J", "Move window down"),
        ("Super + Shift + K", "Move window up"),
        ("Super + Shift + L", "Move window right"),
    ]),
    ("Layouts", [
        ("Super + B", "Split horizontally"),
        ("Super + V", "Split vertically"),
        ("Super + S", "Stacking layout"),
        ("Super + W", "Tabbed layout"),
        ("Super + E", "Toggle split layout"),
        ("Super + F", "Toggle fullscreen"),
        ("Super + Space", "Toggle floating"),
        ("Super + Shift + Space", "Toggle focus mode"),
    ]),
    ("Scratchpad", [
        ("Super + Shift + Minus", "Move to scratchpad"),
        ("Super + Minus", "Show scratchpad"),
    ]),
    ("Workspaces", [
        ("Super + 1..0", "Switch workspace"),
        ("Super + Shift + 1..0", "Move window to workspace"),
    ]),
    ("Resize", [
        ("Super + R", "Enter resize mode"),
        ("← ↑ ↓ → / H J K L", "Resize window"),
        ("Enter / Esc", "Leave resize mode"),
    ]),
    ("Media", [
        ("XF86AudioRaiseVolume", "Volume up"),
        ("XF86AudioLowerVolume", "Volume down"),
        ("XF86AudioMute", "Mute"),
        ("XF86AudioPlay", "Play / Pause"),
        ("XF86AudioNext", "Next track"),
        ("XF86AudioPrev", "Previous track"),
        ("XF86MonBrightnessUp", "Brightness up"),
        ("XF86MonBrightnessDown", "Brightness down"),
    ]),
    ("Mouse", [
        ("Super + Left Mouse", "Move window"),
        ("Super + Right Mouse", "Resize window"),
    ]),
    ("VoidBR", [
        ("Super + F1", "VoidBR Sway Shortcuts"),
    ]),
]

CSS = b"""
window { background:#202225; }
headerbar { background:#2b2d31; }
.title { font-size:18px; font-weight:bold; }
.key { font-family:Monospace; font-weight:bold; color:#8be9fd; }
.desc { color:#f8f8f2; }
.section { font-weight:bold; color:#8be9fd; margin-top:6px; margin-bottom:2px; }
list row { padding:0; }
"""

class Win(Gtk.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title="VoidBR Sway Shortcuts")
        self.set_default_size(760, 600)
        self.set_resizable(False)

        css = Gtk.CssProvider()
        css.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        hb = Gtk.HeaderBar()
        title = Gtk.Label(label="VoidBR Sway Shortcuts")
        title.add_css_class("title")
        hb.set_title_widget(title)
        self.set_titlebar(hb)

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL,
                       spacing=6,
                       margin_top=10, margin_bottom=10,
                       margin_start=12, margin_end=12)

        self.search = Gtk.SearchEntry()
        self.search.set_placeholder_text("Search shortcuts...")
        self.search.connect("search-changed", self.filter_rows)
        root.append(self.search)

        self.listbox = Gtk.ListBox()
        self.listbox.set_selection_mode(Gtk.SelectionMode.NONE)
        self.rows=[]

        for section, items in SHORTCUTS:
            lbl=Gtk.Label(xalign=0)
            lbl.set_markup(f"<b>{section}</b>")
            lbl.add_css_class("section")
            row=Gtk.ListBoxRow(selectable=False)
            row.set_child(lbl)
            self.listbox.append(row)
            self.rows.append((row,section.lower(),True))
            for key,desc in items:
                h=Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL,
                          spacing=16,
                          margin_top=1,margin_bottom=1,
                          margin_start=6,margin_end=6)
                k=Gtk.Label(label=key,xalign=0)
                k.add_css_class("key")
                k.set_size_request(260,-1)
                d=Gtk.Label(label=desc,xalign=0)
                d.add_css_class("desc")
                h.append(k); h.append(d)
                r=Gtk.ListBoxRow(selectable=False)
                r.set_child(h)
                self.listbox.append(r)
                self.rows.append((r,(key+" "+desc).lower(),False))

        sw=Gtk.ScrolledWindow(vexpand=True)
        sw.set_child(self.listbox)
        root.append(sw)

        btn=Gtk.Button(label="Close")
        btn.connect("clicked",lambda *_: self.close())
        root.append(btn)

        self.set_child(root)

        ctrl=Gtk.EventControllerKey()
        ctrl.connect("key-pressed", self.on_key)
        self.add_controller(ctrl)

    def filter_rows(self, entry):
        txt=entry.get_text().lower().strip()
        visible=False
        for row,content,is_section in reversed(self.rows):
            if is_section:
                row.set_visible(visible or txt=="")
                visible=False
            else:
                ok=txt in content
                row.set_visible(ok)
                if ok:
                    visible=True

    def on_key(self, c, keyval, keycode, state):
        if keyval == Gdk.KEY_Escape:
            self.close()
            return True
        return False

class App(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="org.voidbr.shortcuts")
    def do_activate(self):
        Win(self).present()

if __name__=="__main__":
    App().run()

