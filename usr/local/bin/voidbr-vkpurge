# Teste se o terminal suporta caracteres gráficos estendidos
sh_ascii_lines() {
	#Isso força o dialog a usar caracteres ASCII básicos para as bordas.
	#if [[ "$LANG" =~ 'UTF-8' ]]; then
	[[ "$(printf '\u250C')" == "┌" ]]
	export NCURSES_NO_UTF8_ACS=$((!$?))
}

sh_setEnvironment() {
	[[ ! -e "$dialogRcFile" ]] && sh_create_dialogrc
	sh_ascii_lines
}

sh_checkroot() {
	((EUID != 0)) && elevate_to_root "$@" || return 0
}

elevate_to_root() {
	msg "This script must be run as root. Elevating privileges..."
	ccabec+='root [elevated]'
	# Tenta usar sudo primeiro (caso esteja configurado)
	if command -v sudo >/dev/null 2>&1; then
		exec sudo bash "$0" "$@"
	fi
	# Se sudo falhar, tenta su
	if command -v su >/dev/null 2>&1; then
		exec su -c "$0 $*"
	fi
	die "Error: Unable to elevate privileges. Run manually as root."
}

replicate() {
	local char="${1:-#}"
	local nsize="${2:-$(tput cols)}"
	# Gera linha com substituição direta sem forks extras
	printf -v _line "%*s" "$nsize" ""
	printf '%b\n' "${blue}${_line// /$char}${reset}"
}

readconf() {
	local msg="$1"
	local color="${2:-${yellow}}"

	echo -n -e "$color"
	if [[ $LC_DEFAULT -eq 0 ]]; then
		read -r -p "$msg [N/s] :"
	else
		read -r -p "$msg [N/y] :"
	fi
	echo -n -e "$reset"
	case "${REPLY^}" in
	[SY]) return 0 ;;
	"") return 1 ;;
	*) return 1 ;;
	esac
}

debug() {
	# dialog
	whiptail --fb --clear --backtitle "[debug]$0" --title "[debug]$0" --yesno "${*}\n" 0 40
	local result="$?"
	((result)) && exit "$result"
	return "$result"
}

# ===================================================================
# Funções auxiliares
# ===================================================================
run_cmd() {
	local cmd="$*"

	if [[ $DRYRUN -eq 1 ]]; then
		msg "${cyan}[DRY-RUN]${rst} ${cmd}"
	else
		echo -e "  [⚙  ] ${cyan}${cmd}${rst}"
		# Executa o comando, falha se houver erro
		# Redireciona stderr para /dev/null apenas para mkdir -p e ummount -R
		if [[ "$cmd" =~ ^mkdir\ -p ]] || [[ "$cmd" =~ ^umount\ -R ]]; then
			eval "$cmd" &>/dev/null || true
		else
			eval "$cmd" || log_warn_tab "Falha ao executar: $cmd"
		fi
	fi
}

sh_copyright() {
	cat <<-EOF-COPY
		${bold}${cyan}${0##*/} v${_VERSION_}${rst}
		${bold}${cyan}${APPDESC}${rst}
		${bold}${orange}Copyright (c) 2019-2026, ${reset}ChiliLinux Development Team <https://chililinux.com> <https://github.com/chililinux>
		${bold}${orange}Copyright (c) 2019-2026, ${reset}Vilmar Catafesta <vcatafesta@gmail.com>${black}
	EOF-COPY
}

sh_version() {
	cat <<-EOF-VERSION
		  $(sh_copyright)

		        $(gettext "Este é um software livre: você é livre para alterá-lo e redistribuí-lo.")
		        $(gettext "O $APP é disponibilizado para você sob a ${yellow}Licença MIT${black}, e")
		        $(gettext "inclui software de código aberto sob uma variedade de outras licenças.")
		        $(gettext "Você pode ler instruções sobre como baixar e criar para você mesmo")
		        $(gettext "o código fonte específico usado para criar esta cópia.")
		        ${red}$(gettext "Este programa vem com absolutamente NENHUMA garantia.")${reset}
	EOF-VERSION
}

msg() { echo -e "${INFO} ${*}${reset}"; }
log_ok() { echo -e "${TICK} ${*}${reset}"; }
log_err() { echo -e "${CROSS} ${*}${reset}"; }
log_mid() { echo -e "${MID} ${*}${reset}"; }
log_warn() { echo -e "${WARN} ${*}${reset}"; }
msg_tab() { echo -e "  ${INFO} ${*}${reset}"; }
log_ok_tab() { echo -e "  ${TICK} ${*}${reset}"; }
log_err_tab() { echo -e "  ${CROSS} ${*}${reset}"; }
log_mid_tab() { echo -e "  ${MID} ${*}${reset}"; }
log_warn_tab() { echo -e "  ${WARN} ${*}${reset}"; }
die() {
	echo -e "${CROSS} ${red}${*}${reset}"
	exit 1
}

detect_distro() {
	local id=""

	if [[ -r /etc/os-release ]]; then
		# Lê ID=void|arch|debian|... exatamente como a distro declara
		id=$(grep -E '^ID=' /etc/os-release | cut -d= -f2 | tr -d '"')
	elif [[ -r /usr/lib/os-release ]]; then
		id=$(grep -E '^ID=' /usr/lib/os-release | cut -d= -f2 | tr -d '"')
	else
		echo "unknown"
		return
	fi
	echo "$id"
}

sh_checkDependencies() {
	local aBlock_files=()
	local d
	local pkg
	local errorFound=false
	declare -a missing
	local DISTRO
	local cmsgNot
	local cmsgPkg
	DISTRO="$(detect_distro)"
	cmsgNot="$(gettext "Não foi possível encontrar o comando")"
	cmsgPkg="$(gettext "instalar pacote")"

	for d in "${!PACKAGEDEP[@]}"; do
		if ! command -v "$d" &>/dev/null; then
			pkg="${PACKAGEDEP[$d]}"
			log_err "${red}Error${rst}: ${cmsgNot} $(printf "${cyan}%-15s${rst}\n" "$d") -> ${cmsgPkg} ${cyan}${pkg}${rst}"
			missing+=("${pkg}")
			errorFound=true
		else
			#log_msg "Check: ${cyan}$d"
			:
		fi
	done

	if $errorFound; then
		replicate '='
		echo "${yellow}             $(gettext "IMPOSSÍVEL CONTINUAR")"
		echo "${black}$(gettext "Este script precisa dos comandos listados acima")"
		echo "${black}$(gettext "Instale-os e/ou verifique se eles estão em seu") ${red}\$PATH${reset}"
		replicate '='

		local cmd="${DISTRO_MGR[$DISTRO]}"
		#local pkgs="${DISTRO_PKGS[$DISTRO]}"
		local pkgs="${missing[@]}"

		msg_info "Distro detectada: ${cyan}$DISTRO${rst}"
		if readconf "$(gettext "Instalar dependências base agora?")"; then
			echo -e "${blue}::${rst} $(gettext "Preparando ambiente para") ${green}${DISTRO}${reset}..."
			# Execução dinâmica: $cmd (gerenciador) + $pkgs (lista de pacotes)
			if ! $cmd $pkgs; then
				echo
				echo -e "${red}$(gettext "Erro Crítico:")${rst} $(gettext "A instalação dos pacotes básicos falhou.")"
				exit 1
			fi
			echo
			echo -e "${green}$(gettext "Sucesso:")${reset} $(gettext "Dependências instaladas.")"
		fi
	fi
}

# configure ambiente
set_varcolors
sh_checkroot "$@"

##########################################################################################################

# =========================================================
# LOG
# =========================================================

msg() { printf "%s==>%s %s%s%s\n" "$cyan" "$reset" "$white" "$*" "$reset"; }
ok() { printf "%s==>%s %s\n" "$green" "$reset" "$*"; }
warn() { printf "%s==>%s %s\n" "$yellow" "$reset" "$*"; }
err() { printf "%s==>%s %s\n" "$red" "$reset" "$*" >&2; }
fun() { printf "%s==>%s %s\n" "$magenta" "$reset" "$*"; }

usage() {
	cat <<EOF
${cyan}voidbr-vkpurge v${_VERSION_}${reset}
${white}Limpa kernels órfãos do Void Linux com segurança${reset}

${yellow}Uso:${reset}
  ${green}$APP${reset} ${cyan}list${reset} [versão]         ${bold}${cyan}# Lista kernels órfãos (filtra por versão se fornecido)
  ${green}$APP${reset} ${red}rm${reset} all                ${bold}${cyan}# Remove todos os kernels órfãos detectados
  ${green}$APP${reset} ${red}rm${reset} <versão>           ${bold}${cyan}# Remove uma versão específica de kernel
  ${green}$APP${reset} ${magenta}--cleanup${reset}             ${bold}${cyan}# Varredura e remoção automática de órfãos
  ${green}$APP${reset} ${magenta}--force${reset}               ${bold}${cyan}# Força a regeneração do GRUB/bootloader

${yellow}Exemplos:${reset}
  ${rst}$APP list${reset}
  ${rst}$APP rm all${reset}
  ${rst}$APP rm 6.6.32_1${reset}
  ${rst}$APP --cleanup${reset}
  ${rst}$APP --cleanup --force${reset}
EOF
	exit 1
}

require_root() {
	if [ "$(id -u)" -ne 0 ]; then
		err "Execute como root."
		exit 1
	fi
}

# =========================================================
# /BOOT
# =========================================================

check_boot() {
	running="$(uname -r)"
	if [ ! -e "/boot/vmlinuz-$running" ] && [ ! -e "/boot/vmlinux-$running" ]; then
		err "/boot parece não estar montado."
		exit 1
	fi
}

# =========================================================
# HOOKS
# =========================================================

run_hooks() {
	hookdir="$1"
	kver="$2"
	[ -d "/etc/kernel.d/$hookdir" ] || return 0

	for d in "/etc/kernel.d/$hookdir"/*; do
		[ -x "$d" ] || continue
		msg "Executando hook: ${d##*/}"
		(
			cd /
			ROOTDIR=. "$d" kernel "$kver"
		)
	done
}

# =========================================================
# LISTA KERNELS
# =========================================================

list_kernels() {
	running="$(uname -r)"
	installed="$(xbps-query -o "/boot/vmlinu[xz]-*" 2>/dev/null | awk '{print $2}')"

	# Captura o resultado da listagem em uma variável
	local output=$(
		for arg in "${@:-all}"; do
			pattern="$arg"
			[[ "$arg" == "all" ]] && pattern="*"
			for k in /boot/vmlinuz-* /boot/vmlinux-*; do
				[ -e "$k" ] || continue
				[[ "$pattern" == "*" ]] && case "$installed" in *"$k"*) continue ;; esac
				kver="${k##*-}"
				[[ "$kver" == "$running" ]] && continue
				case "$kver" in $pattern) printf "%s\n" "$kver" ;; esac
			done
		done | sort -uV
	)

	# Verifica se a variável está vazia
	if [[ -z "$output" ]]; then
		msg "Nenhum kernel órfão encontrado."
	else
		printf "Kernal órfãos:\n${yellow}%s${rst}\n" "$output"
	fi
}

# =========================================================
# REMOVE ARQUIVOS
# =========================================================

remove_path() {
	target="$1"
	[ -e "$target" ] || return 0
	case "$target" in
	/boot/* | /usr/lib/modules/* | /usr/src/* | /usr/lib/debug/*) ;;
	*)
		err "Recusando remover caminho inseguro: $target"
		exit 1
		;;
	esac
	warn "Removendo: ${yellow}$target${rst}"
	rm -rf -- "$target"
}

remove_kernel() {
	rmkver="$1"
	fun "Kernel ${yellow}$rmkver${rst} será enviado para o além."
	run_hooks pre-remove "$rmkver"

	remove_path "/boot/config-$rmkver"
	remove_path "/boot/System.map-$rmkver"
	remove_path "/boot/vmlinuz-$rmkver"
	remove_path "/boot/vmlinux-$rmkver"
	# ADICIONE ESTA LINHA:
	remove_path "/boot/initramfs-$rmkver.img"
	remove_path "/usr/lib/modules/$rmkver"
	remove_path "/usr/src/kernel-headers-$rmkver"
	remove_path "/usr/lib/debug/boot/vmlinuz-$rmkver"
	remove_path "/usr/lib/debug/usr/lib/modules/$rmkver"
	remove_path "/boot/dtbs/dtbs-$rmkver"
}

# =========================================================
# FINALIZAÇÃO
# =========================================================

finalize_system() {
	msg "Atualizando bootloader..."
	fun "Nada de rodar grub-mkconfig 37 vezes."

	(
		export KERNEL_ACTION="bulk"
		run_hooks post-remove ""
	)
	ok "Bootloader e initramfs atualizados."
}

# =========================================================
# DRY RUN
# =========================================================

dry_run() {
	kernels="$(list_kernels all)"
	msg "Modo simulação ativado."
	echo
	if [ -z "$kernels" ]; then
		ok "Nenhum kernel órfão encontrado."
		exit 0
	fi
	warn "Os seguintes kernels seriam removidos:"
	echo
	printf "  %s\n" $kernels
	echo
	fun "Nenhum arquivo foi alterado."
}

cleanup_orphans() {
	msg "Varrendo o sistema em busca de versões órfãs..."

	# 1. Busca abrangente incluindo config-*
	local found_versions=$({
		find /boot -name "vmlinuz-*" -o -name "vmlinux-*" -o -name "initramfs-*" -o -name "config-*" | sed -E 's/.*-(.*)/\1/; s/\.img//'
		find /usr/lib/modules -maxdepth 1 -mindepth 1 -type d -exec basename {} \;
	} | sort -u)

	local running="$(uname -r)"
	local installed="$(xbps-query -o "/boot/vmlinu[xz]-*" 2>/dev/null | awk '{print $2}')"
	local removed_any=false

	for kver in $found_versions; do
		[[ "$kver" == "$running" ]] && continue
		if [[ -n "$installed" ]] && echo "$installed" | grep -q "vmlinuz-$kver"; then
			continue
		fi

		# 2. Lista todos os arquivos órfãos relacionados a essa versão
		local orphans=$(find /boot -maxdepth 1 -name "*$kver*" -printf "%f ")

		warn "Arquivos órfãos detectados: ${yellow}$orphans${rst}"

		remove_kernel "$kver"
		removed_any=true
	done

	[[ "$removed_any" == "true" ]]
}

# =========================================================
# MAIN
# =========================================================

trap 'err "Operação interrompida."; exit 1' INT TERM HUP

# Variáveis globais de controle
FORCE_REGEN=false
OPT_CLEANUP=false
OPT_FORCE=false
OPT_DRY_RUN=false
COMMAND=""
TARGET_KERNEL=""

while [[ $# -gt 0 ]]; do
	case "$1" in
	--cleanup)
		OPT_CLEANUP=true
		shift
		;;
	--force)
		OPT_FORCE=true
		shift
		;;
	--dry-run)
		OPT_DRY_RUN=true
		shift
		;;
	list | rm)
		COMMAND="$1"
		shift
		# Verifica se o próximo argumento não é um flag (começa com -)
		if [[ -n "$1" && "$1" != -* ]]; then
			TARGET_KERNEL="$1"
			shift
		fi
		;;
	-h | --help) usage ;;
	*) usage ;;
	esac
done

if [[ "$OPT_CLEANUP" == "true" ]]; then
	require_root

	# Se a limpeza encontrar algo (retornar true) OU o force estiver ativo
	if cleanup_orphans || [[ "$OPT_FORCE" == "true" ]]; then
		[[ "$OPT_FORCE" == "true" ]] && msg "Forçando regeneração do bootloader..."
		finalize_system
	else
		msg "Sistema já está limpo. Nada a fazer."
	fi
	exit 0

elif [[ "$COMMAND" == "rm" ]]; then
	require_root
	if [[ -z "$TARGET_KERNEL" ]]; then
		err "Você precisa especificar uma versão ou 'all'."
	fi
	# Sua lógica de remoção aqui
	# ...
	finalize_system # Se remover um kernel específico, sempre atualiza o boot
	exit 0

elif [[ "$COMMAND" == "list" ]]; then
	list_kernels "$TARGET_KERNEL"
	exit 0

else
	usage
fi
