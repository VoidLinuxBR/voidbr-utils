msgstr "#eliminar colores de la salida"

#: usr/local/bin/voidbr-testmirror:737
msgid "#esta ajuda"
msgstr "#esto ayuda"

#: usr/local/bin/voidbr-testmirror:781
msgid "requer um argumento"
msgstr "requiere un argumento"

#: usr/local/bin/voidbr-testmirror:783
msgid "operação não suportada"
msgstr "operación no soportada"

#: usr/local/bin/voidbr-testmirror:783
msgid "usar -h para ajuda"
msgstr "usa -h para ayuda"

#: usr/local/bin/voidbr-testmirror:842
msgid "nenhuma operação especificada (usar -h para ajuda)"
msgstr "no se han especificado operaciones (use -h para obtener ayuda)"

#: usr/local/bin/voidbr-testmirror:843
msgid "apenas uma operação pode ser usada por vez"
msgstr "Sólo se puede utilizar una operación a la vez."
