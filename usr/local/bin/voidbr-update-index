#!/usr/bin/env bash

set -euo pipefail

ISO_BASE_DIR="/vg/void-mirror/iso"
ISO_DIR="/vg/void-mirror/iso/current"
INDEX="/vg/void-mirror/www/voidbr/index.html"

# Cores
RED='\e[1;31m'
GREEN='\e[1;32m'
YELLOW='\e[1;33m'
BLUE='\e[1;34m'
CYAN='\e[1;36m'
RESET='\e[0m'

msg() {
	printf "%b\n" "$1"
}

if ((EUID != 0)); then
	msg "${RED}Erro:${RESET} este script deve ser executado como ${YELLOW}root${RESET}."
	msg "Execute: ${CYAN}sudo $0${RESET}"
	exit 1
fi

[[ -d "$ISO_DIR" ]] || {
	msg "${RED}Erro:${RESET} diretório não encontrado: ${YELLOW}$ISO_DIR${RESET}"
	exit 1
}

voidbr_update_index_html() {
	[[ -f "$INDEX" ]] || {
		msg "${RED}Erro:${RESET} arquivo não encontrado: ${YELLOW}$INDEX${RESET}"
		exit 1
	}

	cp -a "$INDEX" "$INDEX.bak"

	msg "${CYAN}==============================================${RESET}"
	msg "${CYAN}     Atualizador de links do index.html das ISOs VoidBR${RESET}"
	msg "${CYAN}==============================================${RESET}"

	update_iso() {
		local flavor="$1"
		local latest

		latest=$(
			find "$ISO_DIR" -maxdepth 1 \
				-name "voidbr-live-${flavor}-x86_64-*.iso" \
				-printf '%f\n' |
				sort -V |
				tail -n1
		)

		if [[ -z "$latest" ]]; then
			msg "${YELLOW}[SKIP]${RESET} ${flavor}: nenhuma ISO encontrada."
			return
		fi

		msg "${BLUE}[INFO]${RESET} ${flavor}: ${GREEN}${latest}${RESET}"

		sed -Ei \
			"s#iso/voidbr-live-${flavor}-x86_64-[^\"]*\.iso#iso/current/${latest}#g" \
			"$INDEX"
		sed -Ei \
			"s#iso/current/voidbr-live-${flavor}-x86_64-[^\"]*\.iso#iso/current/${latest}#g" \
			"$INDEX"

	}

	for flavor in \
		base \
		xfce \
		gnome \
		plasma \
		cinnamon \
		mate \
		sway; do
		update_iso "$flavor"
	done

	msg ""
	msg "${GREEN}✔ ${INDEX} atualizado com sucesso.${RESET}"
	msg "${CYAN}Backup:${RESET} ${INDEX}.bak"
	msg "Feito!"
	echo
}

voidbr_update_iso_links() {
	local flavor latest link

	msg "${CYAN}==============================================${RESET}"
	msg "${CYAN}     Atualizador de links das ISOs VoidBR${RESET}"
	msg "${CYAN}==============================================${RESET}"

	for flavor in $(find "$ISO_DIR" -maxdepth 1 -name 'voidbr-live-*-x86_64-*.iso' |
		sed -E 's#.*/voidbr-live-([^-]+)-x86_64-.*#\1#' |
		sort -u); do

		latest=$(
			find "$ISO_DIR" -maxdepth 1 \
				-name "voidbr-live-${flavor}-x86_64-*.iso" \
				-printf '%f\n' |
				sort -V |
				tail -n1
		)

		[[ -n "$latest" ]] || continue

		link="voidbr-live-${flavor}-current.iso"

		ln -sfn "current/$latest" "$ISO_BASE_DIR/$link"
		msg "${BLUE}[LINK]${RESET} ${link} ${CYAN}->${RESET} ${GREEN}${latest}${RESET}"
	done
	msg "Feito!"
}

voidbr_archive_old_isos() {
	local flavor latest iso

	mkdir -p "$ISO_BASE_DIR/old"

	msg "${CYAN}==============================================${RESET}"
	msg "${CYAN}     Movendo ISOs antigas para ${ISO_BASE_DIR}/old/${RESET}"
	msg "${CYAN}==============================================${RESET}"

	for flavor in $(find "$ISO_BASE_DIR/current" -maxdepth 1 -name 'voidbr-live-*-x86_64-*.iso' |
		sed -E 's#.*/voidbr-live-([^-]+)-x86_64-.*#\1#' |
		sort -u); do

		latest=$(
			find "$ISO_BASE_DIR/current" -maxdepth 1 \
				-name "voidbr-live-${flavor}-x86_64-*.iso" \
				-printf '%f\n' |
				sort -V |
				tail -n1
		)

		[[ -n "$latest" ]] || continue

		while IFS= read -r iso; do
			iso="${iso##*/}"

			[[ "$iso" == "$latest" ]] && continue

			mv -f \
				"$ISO_BASE_DIR/current/$iso" \
				"$ISO_BASE_DIR/old/$iso"

			msg "${BLUE}[MOVE]${RESET} ${GREEN}${iso}${RESET} ${CYAN}->${RESET} old/"
		done < <(
			find "$ISO_BASE_DIR/current" -maxdepth 1 \
				-name "voidbr-live-${flavor}-x86_64-*.iso" \
				-printf '%f\n'
		)

	done

	msg "${GREEN}Feito!${RESET}"
}

voidbr_update_index_html
voidbr_update_iso_links
voidbr_archive_old_isos
