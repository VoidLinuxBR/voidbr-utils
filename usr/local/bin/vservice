#!/usr/bin/env bash
# -*- coding: utf-8 -*-
# shellcheck shell=bash disable=SC1091,SC2039,SC2166,SC2034
#
#  vservice
#  Wrapper para o sv
#  Created: 18.09.2022 15:10:00 -04
#  Altered: sex 06 fev 2026 04:24:23 -04
#  Updated: qui 30 abr 2026 07:30:00 -04
#  Version: 1.3.6
#
#  Copyright (c) 2026-2026, Vilmar Catafesta <vcatafesta@gmail.com>
#  Assembled By Vilmar Catafesta for the ChiliLinux project.
##############################################################################

export TEXTDOMAINDIR=/usr/share/locale
export TEXTDOMAIN=vservice

SV_DIR="/etc/sv"
ACTIVE_DIR="/var/service"
LOG_FILE="/var/log/vservice.log"

# Serviços críticos protegidos contra parada acidental
PROTECTED_SERVICES=("dbus" "udevd" "socklog-unix" "nanoklogd" "agetty-tty1")

# ─────────────────────────────
# Cores
# ─────────────────────────────
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
RESET='\033[0m'

msg() { echo -e "${GREEN}✔${RESET} $*"; }
warn() { echo -e "${YELLOW}⚠${RESET} $*"; }
err() { echo -e "${RED}✘${RESET} $*" >&2; }
info() { echo -e "${BLUE}➜${RESET} $*"; }

# ─────────────────────────────
# Auditoria e Logs
# ─────────────────────────────

sh_log() {
	local type="$1"
	local msg="$2"
	local timestamp
	timestamp=$(date "+%Y-%m-%d %H:%M:%S")

	# Log para o socklog/syslog
	logger -p user.notice -t vservice "$type: $msg por $USER"

	# Log para o arquivo amigável local
	[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE" 2>/dev/null
	echo "[$timestamp] [$type] $msg (user: $USER)" >>"$LOG_FILE" 2>/dev/null
}

# ─────────────────────────────
# Funções Auxiliares
# ─────────────────────────────

sh_checkroot() {
	((EUID == 0)) && return 0
	if command -v sudo >/dev/null 2>&1; then
		exec sudo bash "$0" "$@"
	elif command -v su >/dev/null 2>&1; then
		exec su -c "$0 $*"
	else
		err "precisa ser root (sem sudo/su disponível)"
		exit 1
	fi
}

check_exists() {
	[[ -d "$SV_DIR/$1" ]]
}

suggest_service() {
	local typed="$1"
	local match
	match=$(ls "$SV_DIR" | grep -m1 "$typed")
	[[ -n "$match" ]] && info "Você quis dizer: ${YELLOW}$match${RESET}?"
}

is_protected() {
	local s="$1"
	for p in "${PROTECTED_SERVICES[@]}"; do
		[[ "$s" == "$p" ]] && return 0
	done
	return 1
}

# Checagem dinâmica: evita o sleep fixo de 7s
wait_for_service() {
	local s="$1"
	local count=0
	local timeout=14 # 14 * 0.5s = 7s máximo

	echo -ne "${BLUE}Aguardando inicialização de ${YELLOW}$s${BLUE}... ${RESET}"

	while [ $count -lt $timeout ]; do
		# Verifica se o sv status contém "run" e tem um PID numérico ativo
		if sv status "$s" 2>/dev/null | grep -qP 'run:.*\(pid \d+\)'; then
			echo -e "${GREEN}OK${RESET}"
			return 0
		fi
		sleep 0.5
		((count++))
	done
	echo -e "${RED}TIMEOUT (Verifique os logs)${RESET}"
	return 1
}

show_status() {
	local SERVICE="$1"
	if command -v vsv >/dev/null; then
		vsv | grep -i "$SERVICE"
	else
		sv status "$SERVICE"
	fi
}

# ─────────────────────────────
# Ações
# ─────────────────────────────

do_enable() {
	local s="$1"
	local active_path="$ACTIVE_DIR/$s"
	local sv_path="$SV_DIR/$s"

	if ! check_exists "$s"; then
		err "serviço '$s' não existe em $SV_DIR"
		suggest_service "$s"
		return 1
	fi

	if [[ -L "$active_path" ]]; then
		warn "serviço '$s' já está habilitado"
	else
		ln -s "$sv_path" "$active_path"
		msg "serviço '$s' habilitado"
		sh_log "ENABLE" "$s"
	fi

	wait_for_service "$s"
	show_status "$s"
}

do_remove() {
	local s="$1"
	local active_path="$ACTIVE_DIR/$s"

	if is_protected "$s"; then
		err "operação negada: '$s' é um serviço protegido."
		return 1
	fi

	if [[ -L "$active_path" ]]; then
		sv stop "$s" >/dev/null 2>&1
		rm -f "$active_path"
		msg "serviço '$s' removido"
		sh_log "REMOVE" "$s"
	else
		warn "serviço '$s' não está habilitado"
	fi
}

do_sv_command() {
	local cmd="$1"
	local s="$2"

	if ! check_exists "$s"; then
		err "serviço '$s' não encontrado"
		suggest_service "$s"
		return 1
	fi

	# Bloqueio de comandos de parada em serviços críticos
	if [[ "$cmd" =~ ^(stop|down|force-stop)$ ]] && is_protected "$s"; then
		err "operação negada: '$s' é crítico para o sistema."
		return 1
	fi

	# Verifica se está habilitado para comandos de execução
	if [[ "$cmd" =~ ^(start|st|up|restart)$ ]] && [[ ! -L "$ACTIVE_DIR/$s" ]]; then
		err "serviço '$s' não está habilitado. Use: vservice enable $s"
		return 1
	fi

	info "sv $cmd $s"
	sv "$cmd" "$s"
	sh_log "COMMAND" "$cmd em $s"

	# Se for comando de subida, usa a espera inteligente
	if [[ "$cmd" =~ ^(start|st|up|restart)$ ]]; then
		wait_for_service "$s"
	fi

	show_status "$s"
}

usage() {
	echo -e "${BLUE}vservice${RESET} — gerenciador de serviços (${YELLOW}runit${RESET})"
	echo
	echo -e "${GREEN}Uso:${RESET}"
	echo -e "  ${BLUE}vservice${RESET} ${YELLOW}{comando}${RESET} ${GREEN}[serviço1] [serviço2] ...${RESET}"
	echo
	echo -e "${GREEN}Comandos:${RESET}"
	echo -e "  ${YELLOW}enable, add${RESET}    — habilita o(s) serviço(s)"
	echo -e "  ${YELLOW}disable${RESET}        — para o serviço (mantém link)"
	echo -e "  ${YELLOW}remove, rm${RESET}     — para e remove o link do(s) serviço(s)"
	echo -e "  ${YELLOW}start, st, up${RESET}  — inicia o(s) serviço(s)"
	echo -e "  ${YELLOW}stop, down${RESET}     — para o(s) serviço(s)"
	echo -e "  ${YELLOW}restart${RESET}        — reinicia o(s) serviço(s)"
	echo -e "  ${YELLOW}status${RESET}         — status do(s) serviço(s)"
	echo -e "  ${YELLOW}list${RESET}           — lista serviços ativos"
	echo
	exit 1
}

# ─────────────────────────────
# Execução Principal
# ─────────────────────────────

[[ $# -lt 1 ]] && usage

# Caso especial: list
if [[ "$1" == "list" ]]; then
	sh_checkroot "$@"
	command -v vsv >/dev/null && vsv || sv status "$ACTIVE_DIR"/*
	exit 0
fi

# Validação para comandos que exigem serviço
[[ $# -lt 2 ]] && usage

sh_checkroot "$@"

ACTION="$1"
shift

for SERVICE in "$@"; do
	case "$ACTION" in
	add | enable | install)
		do_enable "$SERVICE"
		;;
	disable)
		do_sv_command "stop" "$SERVICE"
		;;
	remove | rm)
		do_remove "$SERVICE"
		;;
	start | st | up | stop | down | restart | reload | status | once | pause | exit)
		do_sv_command "$ACTION" "$SERVICE"
		;;
	*)
		usage
		;;
	esac
	#echo -e "${BLUE}---${RESET}"
done
