select_wifi_backend() {
	local options=()
	local choice

	command -v nmcli >/dev/null 2>&1 &&
		options+=(NetworkManager "NetworkManager (recomendado)")

	command -v iwctl >/dev/null 2>&1 &&
		options+=(iwd "iwd")

	command -v wpa_cli >/dev/null 2>&1 &&
		options+=(wpa_supplicant "wpa_supplicant")

	case $((${#options[@]} / 2)) in
	0) return 1 ;;
	1)
		printf '%s\n' "${options[0]}"
		return 0
		;;
	esac

	choice="$(
		${DIALOG} \
			--colors \
			--backtitle "$ccabec" \
			--title "$(gettext "=== WIFI backend ===")" \
			--ok-label "${cmsg_ButtonEscolher}" \
			--cancel-label "${cmsg_Exit}" \
			--insecure "$@" \
			--stdout \
			--menu "\n${YELLOW}$(gettext "Selecione o backend Wi-Fi:")" \
			8 60 0 \
			"${options[@]}"
	)"
	#			15 60 5 \

	exit_status=$?
	case $exit_status in
	"$D_ESC" | "$D_CANCEL")
		exit 0
		;;
	esac
	backend="$choice"
}

sh_get_wifi_backend() {
	if pgrep -x NetworkManagerX >/dev/null 2>&1; then
		printf '%s\n' NetworkManager
	elif pgrep -x iwd >/dev/null 2>&1; then
		printf '%s\n' iwd
	elif pgrep -x wpa_supplicant >/dev/null 2>&1; then
		printf '%s\n' wpa_supplicant
	else
		return 1
	fi
}

sh_get_wifi_interfaces() {
	local i
	for i in /sys/class/net/*; do
		[[ -d "$i/wireless" ]] && basename "$i"
	done
}

sh_get_first_wifi_interface() {
	local i
	for i in /sys/class/net/*; do
		[[ -d "$i/wireless" ]] && {
			basename "$i"
			return 0
		}
	done
	return 1
}

sh_get_wifi_ssid() {
	local iface="${1:-$(sh_get_wifi_interface)}"

	backend="$(sh_get_wifi_backend)" || {
		return 1
	}

	case "${backend}" in
	NetworkManager)
		nmcli -g GENERAL.CONNECTION device show "$iface" 2>/dev/null
		;;
	iwd)
		iwctl station "$iface" show 2>/dev/null | awk -F': ' '/Connected network/ {print $2}'
		;;
	wpa_supplicant)
		wpa_cli -i "$iface" status 2>/dev/null | awk -F= '/^ssid=/{print $2}'
		;;
	esac
	return 0
}

sh_get_ip_iface() {
	local iface="${1:-$(get_wifi_interface)}"
	ip -4 -o addr show dev "$iface" | awk '{print $4}' | head -1
}

sh_get_iface() {
	local array=()
	local iface_array=()
	local wifi
	local line
	local n=0
	local nc=0
	local exit_status
	local sep="\xe2\x94\x82"

	#	# Detecta interfaces wifi
	#	if pgrep -x NetworkManager >/dev/null 2>&1; then
	#		while IFS=: read -r device type state connection; do
	#			[[ "$type" == wifi ]] || continue
	#			[[ -n "$device" ]] || continue
	#			iface_array+=("$device" "")
	#		done < <(
	#			nmcli --terse \
	#				-f DEVICE,TYPE,STATE,CONNECTION \
	#				device status
	#		)
	#	else
	#		for iface in /run/wpa_supplicant/*; do
	#			[[ -S "$iface" ]] || continue
	#			iface="${iface##*/}"
	#			[[ "$iface" == p2p-* ]] && continue
	#			iface_array+=("$iface" "")
	#		done
	#	fi

	# Detecta interfaces wifi
	mapfile -t iface_array < <(sh_get_wifi_interfaces)

	# Nenhuma interface encontrada ?
	if [[ "${#iface_array[@]}" -eq 0 ]]; then
		show_network_diagnostics
		return 1
	fi

	menu_items=()
	for iface in "${iface_array[@]}"; do
		menu_items+=("$iface" "$(cat "/sys/class/net/$iface/device/uevent" 2>/dev/null | grep '^DRIVER=' | cut -d= -f2)")
	done

	# Seleciona interface
	iface=$(${DIALOG} \
		--stdout \
		--colors \
		--backtitle "$ccabec" \
		--title "== WIFI - $(gettext "interface(s) detectada(s)") ==" \
		--ok-label "${cmsg_ButtonEscolher}" \
		--cancel-label "${cmsg_ButtonBack}" \
		--menu "\n${YELLOW}$(gettext "Selecione a interface Wi-Fi:")" \
		8 60 0 \
		"${menu_items[@]}")
	#		"${iface_array[@]}")
	#   2>&1 >/dev/tty)

	exit_status=$?
	case $exit_status in
	"$D_ESC" | "$D_CANCEL")
		return 1
		;;
	esac
	AConfWifi[_INTERFACE]="$iface"
	return 0
}

sh_wifi_scan_networkmanager() {
	while IFS=: read -r \
		inuse \
		b1 b2 b3 b4 b5 b6 \
		ssid mode chan rate signal bars security; do
		[[ -n "$ssid" ]] || continue
		bssid="${b1}:${b2}:${b3}:${b4}:${b5}:${b6}"
		ARRAY_SSID+=("$ssid")
		ARRAY_BSID+=("$bssid")
		ARRAY_SIGNAL+=("$signal")
		ARRAY_FREQUENCY+=("$chan")
		ARRAY_FLAGS+=("$security")
	done < <(
		nmcli --terse \
			--escape no \
			-f IN-USE,BSSID,SSID,MODE,CHAN,RATE,SIGNAL,BARS,SECURITY \
			device wifi list ifname "$iface"
	)
}

sh_wifi_scan_iw() {
    local iface="${1:-$(sh_get_wifi_interface)}"
    local line
    local bssid=""
    local freq=""
    local signal_db=""
    local signal=""
    local ssid=""
    local flags="OPEN"

    ARRAY_SSID=()
    ARRAY_BSID=()
    ARRAY_SIGNAL=()
    ARRAY_FREQUENCY=()
    ARRAY_FLAGS=()

    while IFS= read -r line; do

        case "$line" in

            BSS\ *)
                if [[ -n "$ssid" ]]; then

                    if (( ${signal_db%.*} >= -60 )); then
                        signal="$(sh_signal_to_bars 4)"
                    elif (( ${signal_db%.*} >= -70 )); then
                        signal="$(sh_signal_to_bars 3)"
                    elif (( ${signal_db%.*} >= -80 )); then
                        signal="$(sh_signal_to_bars 2)"
                    else
                        signal="$(sh_signal_to_bars 1)"
                    fi

                    ARRAY_SSID+=("$ssid")
                    ARRAY_BSID+=("$bssid")
                    ARRAY_SIGNAL+=("$signal")
                    ARRAY_FREQUENCY+=("$freq")
                    ARRAY_FLAGS+=("$flags")
                fi

                bssid="${line#BSS }"
                bssid="${bssid%%(*}"

                freq=""
                signal_db=""
                ssid=""
                flags="OPEN"
                ;;
                
            $'\t'freq:*)
                freq="${line##*: }"
                freq="${freq%.*}"
                ;;

            $'\t'signal:*)
                signal_db="${line##*: }"
                signal_db="${signal_db%% *}"
                ;;

            $'\t'SSID:*)
                ssid="${line#*$'\t'SSID: }"
                ;;

            $'\t'RSN:*)
                flags="WPA2/WPA3"
                ;;

            $'\t'WPA:*)
                flags="WPA"
                ;;

        esac

    done < <(iw dev "$iface" scan 2>/dev/null)

    if [[ -n "$ssid" ]]; then

        if (( ${signal_db%.*} >= -60 )); then
            signal="$(sh_signal_to_bars 4)"
        elif (( ${signal_db%.*} >= -70 )); then
            signal="$(sh_signal_to_bars 3)"
        elif (( ${signal_db%.*} >= -80 )); then
            signal="$(sh_signal_to_bars 2)"
        else
            signal="$(sh_signal_to_bars 1)"
        fi

        ARRAY_SSID+=("$ssid")
        ARRAY_BSID+=("$bssid")
        ARRAY_SIGNAL+=("$signal")
        ARRAY_FREQUENCY+=("$freq")
        ARRAY_FLAGS+=("$flags")
    fi
}

sh_wifi_scan_wpa() {
  local iface="${1:-$(sh_get_wifi_interface)}"
  local bssid freq signal_db flags ssid signal

  wpa_cli -i "$iface" scan >/dev/null 2>&1
  sleep 3

  while IFS=$'\t' read -r bssid freq signal_db flags ssid; do
    [[ -z "$ssid" ]] && continue
    case "$signal_db" in
    -[0-4][0-9]) signal="$(sh_signal_to_bars 4)" ;;
    -5[0-9]|-6[0-4]) signal="$(sh_signal_to_bars 3)" ;;
    -6[5-9]|-7[0-9]) signal="$(sh_signal_to_bars 2)" ;;
    *) signal="$(sh_signal_to_bars 1)" ;;
    esac
    ARRAY_SSID+=("$ssid")
    ARRAY_BSID+=("$bssid")
    ARRAY_SIGNAL+=("$signal")
    ARRAY_FREQUENCY+=("$freq")
    ARRAY_FLAGS+=("$flags")
  done < <(
    wpa_cli -i "$iface" scan_results |
    tail -n +3
    )
}

sh_signal_to_bars() {
	case "$1" in
	1) printf "▁   " ;;
	2) printf "▁▃  " ;;
	3) printf "▁▃▆ " ;;
	4) printf "▁▃▆█" ;;
	*) printf "    " ;;
	esac
}

sh_wifi_scan_iwd() {
	local iface="${1:-$(sh_get_wifi_interface)}"
	local raw_line line ssid security signal

	while IFS= read -r raw_line; do

		case "$raw_line" in
		*"Available networks"*) continue ;;
		*"Network name"*) continue ;;
		*"-----"*) continue ;;
		esac

		[[ -z "${raw_line//[[:space:]]/}" ]] && continue

		# Calcula sinal usando ANSI ORIGINAL
		case "$raw_line" in
		*$'\033'[1\;90m'***'$'\033'[0m*)
			signal="$(sh_signal_to_bars 1)"
			;;
		*'**'$'\033'[1\;90m'**'$'\033'[0m*)
			signal="$(sh_signal_to_bars 2)"
			;;
		*'***'$'\033'[1\;90m'*'$'\033'[0m*)
			signal="$(sh_signal_to_bars 3)"
			;;
		*)
			signal="$(sh_signal_to_bars 4)"
			;;
		esac

		# Remove ANSI para parsear texto
		line="$(printf '%s\n' "$raw_line" |
			sed $'s/\033\\[[0-9;]*[[:alpha:]]//g')"

		ssid="$(echo "$line" | cut -c1-34 | xargs)"
		security="$(echo "$line" | cut -c35-55 | xargs)"

		ARRAY_SSID+=("$ssid")
		ARRAY_BSID+=("-")
		ARRAY_SIGNAL+=("$signal")
		ARRAY_FREQUENCY+=("-")
		ARRAY_FLAGS+=("$security")

	done < <(iwctl station "$iface" get-networks)
}

sh_choosewifi() {
	while true; do
		local array=()
		local iface_array=()
		local wifi
		local line
		local n=0
		local nc=0
		local exit_status
		local sep="\xe2\x94\x82"
		unset ARRAY_{SSID,BSID,SIGNAL,FREQUENCY,FLAGS}

		if [[ -z "${iface}" ]]; then
			if ! sh_get_iface; then
				return 1
			fi
		fi

		iface="${AConfWifi[_INTERFACE]}"
		exit_status=$?

		case $exit_status in
		"$D_ESC" | "$D_CANCEL")
			return
			;;
		esac

		sh_info_msg "$(gettext 'Escaneando redes wifi...')"
		#		if ! backend="$(sh_get_wifi_backend)"; then
		#			info \
		#				"WIFI BackEnd" \
		#				"\n${RED}$(gettext "Nenhum backend Wi-Fi encontrado.")" \
		#				"\n${CYAN}$(gettext "Instale o NetworkManager, ou iwd, ou wpa_supplicant.")"
		#			return 1
		#		fi

#		case "$backend" in
#		NetworkManager) sh_wifi_scan_networkmanager ;;
#		iwd) sh_wifi_scan_iwd ;;
#		wpa_supplicant) sh_wifi_scan_iw "${iface}" ;;
#		esac

    sh_wifi_scan_iw "${iface}"

		# Nenhuma rede encontrada
		if [[ "${#ARRAY_SSID[@]}" -eq 0 ]]; then
			info "WIFI" \
				"${RED}$(gettext "Nenhuma rede wifi encontrada.")"
			return 1
		fi

		# Monta menu
		nc=0
		for wifi in "${ARRAY_SSID[@]}"; do
			array[n++]="$nc"
			array[n++]=$(
				printf "%-30s $sep %-17s $sep %3s%% $sep %-20s" \
					"${ARRAY_SSID[$nc]}" \
					"${ARRAY_BSID[$nc]}" \
					"${ARRAY_SIGNAL[$nc]}" \
					"${ARRAY_FLAGS[$nc]}"
			)
			((nc++))
		done

		# Seleciona rede
		wifi=$(${DIALOG} \
			--default-item "0" \
			--backtitle "$ccabec" \
			--title "== WIFI - redes via ${backend} ==" \
			--ok-label "${cmsg_Aceitar}" \
			--cancel-label "${cmsg_ButtonBack}" \
			--colors \
			--menu "\n${YELLOW}$(gettext "Escolha a rede que deseja conectar:")" \
			20 0 0 \
			"${array[@]}" \
			2>&1 >/dev/tty)

		exit_status=$?
		case $exit_status in
		"$D_ESC" | "$D_CANCEL")
			return
			;;
		esac
		_WIFI_NETWORK="${ARRAY_SSID[$wifi]}"
		AConfWifi[_NETWORK]="${ARRAY_SSID[$wifi]}"
		break
	done
}

show_network_diagnostics() {
	local cmsg="
${RED}${REVERSE}$(gettext "Nenhuma interface de Wi-fi encontrada!")${RST}

${YELLOW}$(gettext "Para ativar/levantar a interface de Wi-fi, caso exista,
tente seguir estes passos no terminal:")${RST}

1. $(gettext "Identifique o dispositivo"):${CYAN} $ lspci -knn | grep -iA3 net${RST}
2. $(gettext "ou"):${CYAN} $ lsusb${RST}
3. $(gettext "Carregue o driver necessário"): ${CYAN}$ sudo modprobe <nome_do_driver>${RST}
4. $(gettext "Levante a interface"):${CYAN} $ sudo ip link set <interface> up${RST}
5. $(gettext "Verifique se há firmware faltando"):${CYAN} $ dmesg | grep -i firmware ${RST}
6. $(gettext "(Re)Instale os drivers"):${CYAN} $ sudo xbps-install -Syuf linux-firmware linux-firmware-network${RST}

"

	${DIALOG} \
		--backtitle "${ccabec}" \
		--colors \
		--title "== $(gettext "WIFI - Diagnóstico de Rede") ==" \
		--msgbox "${cmsg}" 0 0
}

sh_nm_release_iface() {
	local iface="$1"

	command -v nmcli >/dev/null 2>&1 || return 0
	nmcli device disconnect "$iface" &>/dev/null
	nmcli device set "$iface" managed no &>/dev/null
}

sh_nm_disable_autoconnect_others() {
    local iface="$1"
    local current_conn="$2"
    local conn

    while read -r conn; do
        [[ -z "$conn" ]] && continue
        [[ "$conn" == "$current_conn" ]] && continue

        [[ "$(nmcli -g connection.interface-name \
              connection show "$conn" 2>/dev/null)" == "$iface" ]] || continue

        nmcli connection modify "$conn" connection.autoconnect no
    done < <(
        nmcli -t -f NAME connection show
    )
}

sh_confWifi() {
	local iface
	local wlanip
	local cextra

	#	if iface="$(sh_get_wifi_interface)"; then
	if sh_get_iface; then
		select_wifi_backend
		if ! _WIFI_CONNECTED="$(sh_get_wifi_ssid "$iface")"; then
			info \
				"WIFI BackEnd" \
				"\n${RED}$(gettext "Nenhum backend Wi-Fi encontrado.")" \
				"\n${CYAN}$(gettext "Instale o NetworkManager, ou iwd, ou wpa_supplicant.")"
			return 1
		fi
		wlanip="$(sh_get_ip_iface "$iface")"
		_WIFI_NETWORK="$_WIFI_CONNECTED"
	else
		#		info \
		#			"WIFI interface" \
		#			"\n${RED}$(gettext "Nenhuma interface Wi-Fi encontrado.")"
		#		return 1
		exit 0
	fi

	#debug "1=$_WIFI_NETWORK 2=$_WIFI_CONNECTED"

	cextra+="➡ ${YELLOW}$(gettext 'Deixe em branco o campo Interface Wi-Fi para listar interfaces')\n"
	cextra+="➡ ${YELLOW}$(gettext 'Deixe em branco o campo Rede Wi-Fi para escanear redes')"
	iface_edit=0
	rede_edit=0
	senha_edit=1

	while true; do
		exec 3>&1
		wifitext=$(
			${DIALOG} \
				--stdout \
				--title "$(gettext "=== WIFI ===")" \
				--colors \
				--ok-label "${cmsg_Conectar}" \
				--cancel-label "${cmsg_ButtonBack}" \
				--backtitle "$ccabec" \
				--insecure "$@" \
				--extra-button \
				--extra-label "Scan wifi" \
				--mixedform "${cmsg_MENU}\n\n${cextra}" \
				19 80 7 \
				"Interface             : " 1 1 "$iface" 1 20 40 0 2 \
				"Backend               : " 2 1 "$backend" 2 20 40 0 2 \
				"Rede conectada        : " 3 1 "$_WIFI_CONNECTED" 3 20 40 0 2 \
				"Ip                    : " 4 1 "$wlanip" 4 20 40 0 2 \
				"${cmsg_interfacewifi} : " 5 1 "${iface}" 5 20 40 0 $iface_edit \
				"${cmsg_redewifi}      : " 6 1 "$_WIFI_NETWORK" 6 20 40 0 $rede_edit \
				"${cmsg_senhawifi}     : " 7 1 "$_WIFI_PASSWORD" 7 20 40 0 $senha_edit
		)
		#			2>&1 1>&3)

		exit_status=$?
		case $exit_status in
		"$D_ESC" | "$D_CANCEL")
			return
			;;
		"$D_OK")
			mapfile -t aWifi <<<"$wifitext"
			#      debug "" "0-${aWifi[0]}\n" \
			#            "1-${aWifi[1]}\n" \
			#            "2-${aWifi[2]}\n" \
			#            "3-${aWifi[3]}\n" \
			#            "4-${aWifi[4]}\n" \
			#            "5-${aWifi[5]}\n" \
			#            "6-${aWifi[6]}\n"
			#            "7-${aWifi[7]}\n"

			iface="${aWifi[4]}"
			_WIFI_NETWORK="${aWifi[5]}"
			_WIFI_PASSWORD="${aWifi[6]}"
			AConfWifi[_NETWORK]="${aWifi[5]}"
			AConfWifi[_PASSWORD]="${aWifi[6]}"
			LWIFI=1

			if [[ -z "${iface}" ]]; then
				if sh_get_iface; then
					iface="${AConfWifi[_INTERFACE]}"
					iface_edit=2
				fi
				continue
			fi
			iface_edit=2

			if [[ -z "${AConfWifi[_NETWORK]}" ]]; then
				sh_choosewifi
				rede_edit=2
				continue
			fi

			USE_STATIC_IP=false
			if conf "=== IP SERVER ===" \
				"\nInterface: ${CYAN}${iface}${RST}" \
				"\nBackend  : ${CYAN}${backend}${RST}" \
				"\nNetwork  : ${CYAN}${AConfWifi[_NETWORK]}${RST}" \
				"\n\n${BOLD}${RED}$(gettext "Deseja configurar IP fixo?")\n\n"; then
				USE_STATIC_IP=true
				sh_configure_dhcpcd_static_ip_dialog
			fi

      sh_info_msg "$(gettext 'Configurando conexao')"

#      sh_cmd_job_infobox "Aguarde alguns instantes, sincronizando e atualizando..." \
#          "xbps-install -Syuf --ignore-file-conflicts "${PackagesToUpdate[@]}" &>/dev/null"

			case "${backend}" in
			NetworkManager)
        sh_cmd_job_infobox "Removendo conexao antiga..." \
          "nmcli connection delete ${_WIFI_NETWORK}"

				if output=$(
					nmcli device wifi connect "${_WIFI_NETWORK}" \
						password "${_WIFI_PASSWORD}" \
						ifname "$iface" 2>&1
				); then
  				sleep 0.5

          if $USE_STATIC_IP; then
            AsDhcp[CONNECTION]=$(nmcli -g GENERAL.CONNECTION device show "$iface")
            sh_save_nm_static_ip "${AsDhcp[CONNECTION]}"
            nmcli connection down "${AsDhcp[CONNECTION]}" >/dev/null 2>&1
            nmcli connection up "${AsDhcp[CONNECTION]}" >/dev/null 2>&1
            sleep 0.5
          fi

					wifi_ip=$(nmcli -g IP4.ADDRESS device show "$iface" | head -n1)
					wifi_gateway=$(nmcli -g IP4.GATEWAY device show "$iface" | head -n1)
					wifi_dns=$(nmcli -g IP4.DNS device show "$iface" | paste -sd ',')

          sh_nm_disable_autoconnect_others \
            "$iface" \
            "$_WIFI_NETWORK"

				fi
        ;;

			iwd)
				# DHCP = remove bloco estático
				sh_remove_dhcpcd_conf_iface

				# IP fixo = recria bloco
				if $USE_STATIC_IP; then
					sh_save_dhcpcd_static_ip
				fi

				# garante que o dhcpcd releia a configuração
				dhcpcd -k "$iface" 2>/dev/null

				# libera outra conexao se existir
				sh_nm_release_iface "$iface"

				# conecta!
				iwctl --passphrase "$_WIFI_PASSWORD" \
					station "$iface" connect "$_WIFI_NETWORK"

				# solicita configuração IP
				dhcpcd "$iface" 2>/dev/null
				;;

			wpa_supplicant)
				# DHCP = remove bloco estático
				sh_remove_dhcpcd_conf_iface

				# IP fixo = recria bloco
				if $USE_STATIC_IP; then
					sh_save_dhcpcd_static_ip
				fi

				# garante que o dhcpcd releia a configuração
				dhcpcd -k "$iface" 2>/dev/null

				# libera outra conexao se existir
				sh_nm_release_iface "$iface"

				# gerar conf
				wpa_cli -i "$iface" terminate >/dev/null 2>&1 || true
				rm -f "/etc/wpa_supplicant/wpa_supplicant-$iface.conf" >/dev/null 2>&1 || true
				wpa_passphrase \
				  "$_WIFI_NETWORK" \
				  "$_WIFI_PASSWORD" >/etc/wpa_supplicant/wpa_supplicant-"$iface".conf

        # conecta!
        wpa_supplicant \
            -B \
            -i "$iface" \
            -c "/etc/wpa_supplicant/wpa_supplicant-$iface.conf"

				# solicita configuração IP
				dhcpcd "$iface" 2>/dev/null
				;;
			esac

      if [[ $? -eq 0 ]]; then
			  info "${_WIFI_NETWORK}" "\
${GREEN}Conectado com sucesso!${RST}\n\n\
Interface: ${YELLOW}$iface${RST}\n\
SSID     : ${YELLOW}${_WIFI_NETWORK}${RST}\n\
BSSID    : $bssid\n\
IP       : ${YELLOW}${wifi_ip:-N/A}${RST}\n\
Gateway  : ${wifi_gateway:-N/A}\n\
DNS      : ${wifi_dns:-N/A}\n\
Sinal    : ${signal:-N/A}%\n\
Segurança: ${security:-N/A}\n\
"
      else
  			if conf "WIFI" \
	  			"${RED}Falha ao conectar.${RST}\n\n" \
  				"result: $output" \
	  			"\n\n${BOLD}${RED}$(gettext "Deseja escanear por redes wifi?")\n\n"; then
		  		sh_choosewifi
			  	continue
  			fi
      fi
			;;
		3)
			sh_choosewifi
			continue
			;;
		esac
		exec 3>&-
		return 0
	done
}

sh_setEnvironment
sh_setLanguage
sh_setVarColors
sh_setAsciiLines
sh_setLogPrefix
sh_checkroot "$@"
sh_confWifi
