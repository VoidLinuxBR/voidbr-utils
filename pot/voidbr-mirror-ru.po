#: usr/local/bin/voidbr-mirror:54
msgid "Interrompido! Saindo..."
msgstr "Прервано! Уход..."

#: usr/local/bin/voidbr-mirror:97
msgid "Removendo arquivos temporários..."
msgstr "Удаление временных файлов..."

#: usr/local/bin/voidbr-mirror:323
msgid "verificando caminho"
msgstr "проверка пути"

#: usr/local/bin/voidbr-mirror:674
msgid "LISTA DE ESPELHOS"
msgstr "СПИСОК ЗЕРКАЛ"

#: usr/local/bin/voidbr-mirror:674
msgid "Não é possível continuar!"
msgstr "Не могу продолжать!"

#: usr/local/bin/voidbr-mirror:675
msgid "Arquivo de lista de espelhos não encontrado no caminho"
msgstr "Файл списка зеркал не найден по пути"

#: usr/local/bin/voidbr-mirror:748 usr/local/bin/voidbr-mirror:752
#: usr/local/bin/voidbr-mirror:756 usr/local/bin/voidbr-mirror:885
msgid "=== ESPELHO ==="
msgstr "=== ЗЕРКАЛО ==="

#: usr/local/bin/voidbr-mirror:748 usr/local/bin/voidbr-mirror:754
msgid "Aguarde..."
msgstr "Ждать..."

#: usr/local/bin/voidbr-mirror:748 usr/local/bin/voidbr-mirror:754
msgid "testando com"
msgstr "тестирование с"

#: usr/local/bin/voidbr-mirror:751
msgid "não retornou resultado"
msgstr "не вернул результат"

#: usr/local/bin/voidbr-mirror:756
msgid "não foi localizado no"
msgstr "не находился в"

#: usr/local/bin/voidbr-mirror:757
msgid "não foi localizado em"
msgstr "не находился в"

#: usr/local/bin/voidbr-mirror:772
msgid "Deseja definir/alterar o espelho deste host para o(s) escolhido(s) ?"
msgstr "Вы хотите установить/изменить зеркало этого хоста на выбранный(ые)?"

#: usr/local/bin/voidbr-mirror:818 usr/local/bin/voidbr-mirror:820
msgid "BAIXAR LISTA DE ESPELHOS"
msgstr "СКАЧАТЬ СПИСОК ЗЕРКАЛ"

#: usr/local/bin/voidbr-mirror:818
msgid "Buscando nova lista de espelhos em"
msgstr "Ищем новый список зеркал в"

#: usr/local/bin/voidbr-mirror:821
msgid "Verifique sua conexão com a internet"
msgstr "Проверьте подключение к Интернету"

#: usr/local/bin/voidbr-mirror:822
msgid "Incapaz de buscar uma nova lista de espelhos de"
msgstr "Не удалось получить новый список зеркал."

#: usr/local/bin/voidbr-mirror:823
msgid "Tentando usar a lista local"
msgstr "Попытка использовать локальный список"

#: usr/local/bin/voidbr-mirror:863
msgid "erro: você não pode realizar esta operação a menos que seja root."
msgstr "ошибка: вы не сможете выполнить эту операцию, если вы не являетесь пользователем root."

#: usr/local/bin/voidbr-mirror:864
msgid "ERRO"
msgstr "ОШИБКА"

#: usr/local/bin/voidbr-mirror:865
msgid "não encontrei o comando"
msgstr "Я не нашел команду"

#: usr/local/bin/voidbr-mirror:866
msgid "IMPOSSÍVEL CONTINUAR"
msgstr "НЕВОЗМОЖНО ПРОДОЛЖАТЬ"

#: usr/local/bin/voidbr-mirror:867
msgid "Esse script precisa dos comandos listados acima"
msgstr "Этот скрипт нуждается в командах, перечисленных выше."

#: usr/local/bin/voidbr-mirror:868
msgid "Instale-os e/ou verifique se estão no seu"
msgstr "Установите их и/или проверьте, есть ли они на вашем компьютере."

#: usr/local/bin/voidbr-mirror:869
msgid "Instalar o(s) comando(s)"
msgstr "Установите команду(ы)"

#: usr/local/bin/voidbr-mirror:870
msgid "INFO: Rode novamente o aplicativo"
msgstr "ИНФОРМАЦИЯ: Запустите приложение еще раз."

#: usr/local/bin/voidbr-mirror:871
msgid "ERRO na instalação dos comandos. Tente manualmente."
msgstr "Ошибка установки команд. Попробуйте вручную."

#: usr/local/bin/voidbr-mirror:872
msgid "Instalação abortada"
msgstr "Установка прервана"

#: usr/local/bin/voidbr-mirror:873
msgid "Ok"
msgstr "Хорошо"

#: usr/local/bin/voidbr-mirror:874
msgid "Aceitar"
msgstr "Принять"

#: usr/local/bin/voidbr-mirror:875
msgid "Sair"
msgstr "Чтобы выйти"

#: usr/local/bin/voidbr-mirror:876
msgid "Sim"
msgstr "Сим"

#: usr/local/bin/voidbr-mirror:877
msgid "Não"
msgstr "Нет"

#: usr/local/bin/voidbr-mirror:878
msgid "Gerando"
msgstr "Создание"

#: usr/local/bin/voidbr-mirror:879
msgid "Atualizando espelhos..."
msgstr "Обновление зеркал..."

#: usr/local/bin/voidbr-mirror:880
msgid "Usar as setas ↑ e ↓ para navegar."
msgstr "Для навигации используйте стрелки ↑ и ↓."

#: usr/local/bin/voidbr-mirror:881
msgid "Usar TAB para alternar entre os botões."
msgstr "Используйте TAB для переключения между кнопками."

#: usr/local/bin/voidbr-mirror:882
msgid "Usar ENTER ou BARRA DE ESPAÇO para selecionar e aceitar."
msgstr "Используйте ВВОД или ПРОБЕЛ, чтобы выбрать и принять."

#: usr/local/bin/voidbr-mirror:884
msgid "Configurando espelho em"
msgstr "Настройка зеркала на"
