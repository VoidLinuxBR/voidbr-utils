	if [[ -z $(command -v "$1") ]]; then
		#		echo "$(gettext "não disponível")"
		"$(gettext "não disponível")"
	else
		#		echo "$(gettext "mais avançado")"
		"$(gettext "mais avançado")"
	fi
}

sh_loadconf() {
	if ! $LCHROOT; then
		sh_info_msg "$(gettext 'Loading configuration file'): ${yellow}$app_conf"
	fi

	if [ -f "$app_conf" ] && [ -r "$app_conf" ]; then
		# shellcheck source=/dev/null
		source "$app_conf"
		evaluate_retval "$?"
		sh_parseconf
	else
		evaluate_retval "$?" 1 "${cmsg_falhaAbertura} $app_conf!"
	fi
}

sh_parseconf() {
	if ! $LCHROOT; then
		sh_info_msg "$(gettext 'Analisando o arquivo de configuração'): ${yellow}$app_conf"
	fi
	#evaluate_retval "${PIPESTATUS[0]}" "$err_not_fatal"
}

get_default_iface() {
	ip route | awk '/default/ {print $5; exit}'
}

sh_configure_dhcpcd_static_ip_dialog() {
	local CONFIG_FILE="/etc/dhcpcd.conf"
	local DEFAULT_IFACE

	# detecta interface padrão
	DEFAULT_IFACE="$(get_default_iface)"

	sh_setAsDhcp

	# formulário
	while true; do
		exec 3>&1
		dhcptext=$(dialog \
			--backtitle "$ccabec" \
			--title "$(gettext "Configuração de IP fixo (dhcpcd)")" \
			--form "$(gettext "Preencha os dados:")" \
			15 60 6 \
			"$(gettext "Interface:")" 1 1 "${AsDhcp[IFACE]}" 1 25 20 0 \
			"$(gettext "IP:")" 2 1 "${AsDhcp[IP]}" 2 25 20 0 \
			"$(gettext "Máscara (CIDR):")" 3 1 "${AsDhcp[CIDR]}" 3 25 20 0 \
			"$(gettext "Gateway:")" 4 1 "${AsDhcp[GATEWAY]}" 4 25 20 0 \
			"$(gettext "DNS 1:")" 5 1 "${AsDhcp[DNS1]}" 5 25 20 0 \
			"$(gettext "DNS 2:")" 6 1 "${AsDhcp[DNS2]}" 6 25 20 0 \
			2>&1 >/dev/tty)

		exit_status=$?
		case $exit_status in
		"$D_ESC" | "$D_CANCEL")
			return
			;;
		"$D_OK")
			# extrai valores
			mapfile -t adhcp <<<"$dhcptext"
			AsDhcp[IFACE]="${adhcp[0]}"
			AsDhcp[IP]="${adhcp[1]}"
			AsDhcp[CIDR]="${adhcp[2]}"
			AsDhcp[GATEWAY]="${adhcp[3]}"
			AsDhcp[DNS1]="${adhcp[4]}"
			AsDhcp[DNS2]="${adhcp[5]}"

			# mensagem confirmação
			CONFIRM_MSG="$(printf "%s\n\n%s: %s\n%s: %s/%s\n%s: %s\n%s: %s %s" \
				"${BOLD}${RED}$(gettext "Aplicar essas configurações?")" \
				"${RESET}$(gettext "Interface")" "${AsDhcp[IFACE]}" \
				"$(gettext "IP")" "${AsDhcp[IP]}" "${AsDhcp[CIDR]}" \
				"$(gettext "Gateway")" "${AsDhcp[GATEWAY]}" \
				"$(gettext "DNS")" "${AsDhcp[DNS1]}" "${AsDhcp[DNS2]}")"

			#   dialog --yesno "$CONFIRM_MSG" 12 50
			if conf "=== DHCP ===" "$CONFIRM_MSG"; then
				LDHCP=true
			fi
			;;
		esac
		exec 3>&-
		return 0
	done
}

sh_remove_dhcpcd_conf_iface() {
	sed -i \
		"/^# BEGIN VOIDBR-WIFI-${iface}\$/,/^# END VOIDBR-WIFI-${iface}\$/d" \
		/etc/dhcpcd.conf
}

sh_save_nm_static_ip() {
  local conn="$1"

  nmcli connection modify "$conn" \
    ipv4.method manual \
    ipv4.addresses "${AsDhcp[IP]}/${AsDhcp[CIDR]}" \
    ipv4.gateway "${AsDhcp[GATEWAY]}" \
    ipv4.dns "${AsDhcp[DNS1]} ${AsDhcp[DNS2]}" \
    connection.autoconnect yes
}

sh_save_dhcpcd_static_ip() {
	local conf="/etc/dhcpcd.conf"
	local BACKUP_FILE="${conf}.$(sh_diahora)"

	sed -i \
		"/^interface ${AsDhcp[IFACE]}\$/,/^$/d" \
		"$conf"

	sh_info_msg "%(gettext 'Aplicando configuração do dhcpd')"
	# backup somente se existir
	if [[ -f "$conf" ]]; then
		mv -f "$conf" "$BACKUP_FILE"
	fi

	cat >>"$conf" <<EOF
# BEGIN VOIDBR-WIFI-wlo1
interface ${AsDhcp[IFACE]}
static ip_address=${AsDhcp[IP]}/${AsDhcp[CIDR]}
static routers=${AsDhcp[GATEWAY]}
static domain_name_servers=${AsDhcp[DNS1]} ${AsDhcp[DNS2]}
# END VOIDBR-WIFI-wlo1

EOF
}

pcount() {
	local -i nargs="$#"

	echo $nargs
	[[ nargs -gt 0 ]] && return 0 || return 1
}

strtoarray() {
	local anew

	IFS=' ' read -r -a anew <<<"$1"
	echo "${anew[@]}"
}

lenarraystr() {
	local new=$1

	read -ra ADDR <<<"$new"
	echo "${#ADDR[@]}"
}

