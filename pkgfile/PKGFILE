pkgname=voidbr-utils
pkgdesc="Utilitários do sistema essenciais para uso diário no VoidBR"
pkgver=$(date +%Y%m%d)
pkgrel=$(date +%H%M)
provides=()
replaces=()
arch=('any')
license=('GPL3')
url="https://github.com/voidlinuxbr/$pkgname"
source=("git+${url}.git")
md5sums=('SKIP')
depends=("bash>=0" smartmontools umc pigz geoip geoipupdate)

package() {
	local dirs=("usr" "etc" "opt")
	#   echo "DESTDIR=$DESTDIR"
	#   echo "pkgdir=$pkgdir"
	#   echo "srcdir=$srcdir"
	#   echo "_pkgsrc=$_pkgsrc"

	cd ${srcdir}/${pkgname}
	for dir in "${dirs[@]}"; do
		if [ -d "${_pkgsrc}/${dir}" ]; then
			cp -a "${_pkgsrc}/${dir}" "$DESTDIR/"
		fi
	done
}

pre_install() {
  log "Iniciando instalação"
}

post_install() {
  log "Finalizando instalação"
}

pre_upgrade() {
  log "Iniciando upgrade"
}

post_upgrade() {
  log "Finalizando upgrade"
}
