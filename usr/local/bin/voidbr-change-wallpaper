#!/bin/bash

DIR="/usr/share/backgrounds/voidbr"

mapfile -t imagens < <(
    find "$DIR" -type f \( \
        -iname "*.jpg"  -o \
        -iname "*.jpeg" -o \
        -iname "*.png"  -o \
        -iname "*.webp" -o \
        -iname "*.avif" -o \
        -iname "*.heic" \
    \)
)

(( ${#imagens[@]} )) || exit 1

anterior=-1

while :; do
    if (( ${#imagens[@]} > 1 )); then
        while :; do
            indice=$((RANDOM % ${#imagens[@]}))
            (( indice != anterior )) && break
        done
        anterior=$indice
    else
        indice=0
    fi

    img="${imagens[indice]}"

    if [[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]]; then
        # Compatibilidade com o comportamento anterior
        hyprctl hyprpaper wallpaper ",$img"

    elif [[ -n "$WAYLAND_DISPLAY" ]] && command -v swaybg >/dev/null; then
        pkill -x swaybg 2>/dev/null
        swaybg -i "$img" -m fill &
    fi

    sleep 60
done
