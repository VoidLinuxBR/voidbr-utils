export LANGUAGE="${LANGUAGE:-pt_BR}"
export TEXTDOMAINDIR=/usr/share/locale
export TEXTDOMAIN=voidbr-mirror

#debug
export PS4=$'${red}${0##*/}${green}[$FUNCNAME]${pink}[$LINENO]${reset} '
#set -x
#set -e

#system
readonly APP="${0##*/}"
readonly APPBASE="voidbr-mirror"
readonly APPVERSION='3.2.15-20260215'
readonly DEPENDENCIES=(wget curl dialog cat sed grep printf)
#
declare -gA Amirrors
declare -gi quiet=0
declare -gi grafico=1
declare -gi ncontador=0
declare _MIRROR="repo-fastly.voidlinux.org"
declare BOOTLOG
declare Interrupted
Interrupted="$(gettext "Interrompido! Saindo...")"
trap 'printf "\n${red}$Interrupted\n"; cleanup; exit 0' INT TERM HUP
declare dialogRcFile="$HOME/.dialogrc"

has_command() {
  command -v "$1" >/dev/null && return 0 || return 1
}

detect_distro() {
  local id=""

  if [[ -r /etc/os-release ]]; then
    # Lê ID=void|arch|debian|... exatamente como a distro declara
    id=$(grep -E '^ID=' /etc/os-release | cut -d= -f2 | tr -d '"')
  elif [[ -r /usr/lib/os-release ]]; then
    id=$(grep -E '^ID=' /usr/lib/os-release | cut -d= -f2 | tr -d '"')
  else
    echo "unknown"
    return
  fi
  echo "$id"
}

debug() {
	whiptail \
		--fb \
		--clear \
		--backtitle "[debug]$0" \
		--title "[debug]$0" \
		--yesno "${*}\n" \
		0 40
	result=$?
	if ((result)); then
		exit
	fi
	return $result
}

info_msg() {
	printf "%s" "\033[1m$*\n\033[m"
}

cleanup() {
	info_msg "$(gettext "Removendo arquivos temporários...")"
	rm -fv "$BOOTLOG"
	exit 1
}

