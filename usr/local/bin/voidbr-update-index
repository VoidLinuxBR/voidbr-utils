#!/usr/bin/env bash

set -euo pipefail

ISO_DIR="/vg/void-mirror/iso"
INDEX="/vg/void-mirror/www/voidbr/index.html"

# Cores
RED='\e[1;31m'
GREEN='\e[1;32m'
YELLOW='\e[1;33m'
BLUE='\e[1;34m'
CYAN='\e[1;36m'
RESET='\e[0m'

msg() {
	printf "%b\n" "$1"
}

if (( EUID != 0 )); then
    msg "${RED}Erro:${RESET} este script deve ser executado como ${YELLOW}root${RESET}."
    msg "Execute: ${CYAN}sudo $0${RESET}"
    exit 1
fi

[[ -d "$ISO_DIR" ]] || {
	msg "${RED}Erro:${RESET} diretório não encontrado: ${YELLOW}$ISO_DIR${RESET}"
	exit 1
}

[[ -f "$INDEX" ]] || {
	msg "${RED}Erro:${RESET} arquivo não encontrado: ${YELLOW}$INDEX${RESET}"
	exit 1
}

cp -a "$INDEX" "$INDEX.bak"

msg "${CYAN}==============================================${RESET}"
msg "${CYAN}     Atualizador de links das ISOs VoidBR${RESET}"
msg "${CYAN}==============================================${RESET}"
msg ""

update_iso() {
	local flavor="$1"
	local latest

	latest=$(
		find "$ISO_DIR" -maxdepth 1 \
			-name "voidbr-live-${flavor}-x86_64-*.iso" \
			-printf '%f\n' |
			sort -V |
			tail -n1
	)

	if [[ -z "$latest" ]]; then
		msg "${YELLOW}[SKIP]${RESET} ${flavor}: nenhuma ISO encontrada."
		return
	fi

	msg "${BLUE}[INFO]${RESET} ${flavor}: ${GREEN}${latest}${RESET}"

	sed -Ei \
		"s#iso/voidbr-live-${flavor}-x86_64-[^\"]*\.iso#iso/${latest}#g" \
		"$INDEX"
}

for flavor in \
	base \
	xfce \
	gnome \
	plasma \
	cinnamon \
	mate \
	sway; do
	update_iso "$flavor"
done

msg ""
msg "${GREEN}✔ ${INDEX} atualizado com sucesso.${RESET}"
msg "${CYAN}Backup:${RESET} ${INDEX}.bak"
