sh_run_clean() {
	local ret

	eval "$1" 2>&1 |
		strip_ansi |
		tee -i -a "$BOOTLOG" \
			>"$LOGGER"
	ret="${PIPESTATUS[0]}"

	return "$ret"
}

strip_ansi() {
	printf '%s' "$1" |
		sed -E '
      s/\x1B\[[0-9;]*m//g;      # Remove SGR (Cores, negrito, etc: 1m, 38;5;196m)
      s/\x1B\[[0-9;?]*[@-~]//g; # Remove outros CSI (Movimento de cursor, etc)
      s/\x1B\([a-zA-Z]//g;      # Remove Charset (O ^[(B que apareceu antes)
      s/\x1B[@-Z\\-_]//g;       # Remove escapes de 2 caracteres
    '
}

sh_cmd_job() {
	local cmsg="$1"
	local cjob="$2"
	local erro_fatal="$3"
	local lretval=0

	cmsg+=" ${cmsg_Em}"
	last_msg="$cmsg"
	msg "INFO" "$last_msg" "$(log_info_msg "$last_msg")"

	if ((grafico)); then
		read LINES COLUMNS <<<"$(stty size)"
		cmsg=$(strip_ansi "$cmsg")
		eval "$cjob" 2>&1 | tee -i -a "$BOOTLOG" |
			${DIALOG} \
				--colors \
				--backtitle "$ccabec" \
				--title "\Zb\Z3Step:$ufmt \Z1==>\Zn \Z7[$cmsg]\Zn \Z6[$(sh_time_elapsed)]\Zn" \
				--progressbox $((MAXROW / 2)) $((MAXCOL - 20))
	else
		eval "$cjob" 2>&1 | tee -i -a "$BOOTLOG" >$LOGGER
	fi

	lretval="${PIPESTATUS[0]}"
	evaluate_retval "$lretval" "$erro_fatal"
	shell='/bin/sh'
	return "$lretval"
}

sh_diahora() {
	DIAHORA=$(date +"%d%m%Y-%T" | sed 's/://g')
	printf "%s\n" "$DIAHORA"
}

sh_rtrim() {
	local str="$1"
	echo "${str%%' '}"
}

