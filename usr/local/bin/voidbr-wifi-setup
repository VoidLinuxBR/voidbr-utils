sh_cmd_job_infobox() {
	local cmsg="$1"
	local cjob="$2"
	local erro_fatal="$3"
	local lretval=0

	# Cria um log temporário exclusivo
	local tmp_log=$(mktemp)

	# Executa o comando localmente e captura o código de saída
	eval "$cjob" >"$tmp_log" 2>&1 &
	local pid_job=$!

	# Exibe o log em tempo real usando dialog --infobox
	if ((grafico)); then
		while kill -0 "$pid_job" 2>/dev/null; do
			${DIALOG} \
				--no-collapse \
				--colors \
				--title "$cmsg - (log realtime)" \
				--backtitle "$ctitle" \
				--infobox "$(tail -n 13 "$tmp_log")" \
				15 100
			sleep 0.3
		done
	fi

	# Aguarda o término do comando e captura o código de saída
	wait "$pid_job"
	lretval=$?

	# Remove o log temporário
	rm -f "$tmp_log"

	# Avalia o resultado da execução
	[[ -z "$erro_fatal" ]] && return "$lretval" || return "$erro_fatal"
}

sh_msg_job() {
	local cmsg="$1"
	local cjob="$2"
	local erro_fatal="$3"
	local lretval=0

	last_msg="$cmsg"
	msg "INFO" "$last_msg" "$(log_info_msg "$last_msg")"
	lretval=0
	evaluate_retval "$lretval" "$erro_fatal"
	return "$lretval"
}

