#!/usr/bin/env bash

set -euo pipefail

ISO_BASE_DIR="/vg/void-mirror/iso"
ISO_DIR="/vg/void-mirror/iso/current"
INDEX="/vg/void-mirror/www/voidbr/index.html"

# Cores
RED='\e[1;31m'
GREEN='\e[1;32m'
YELLOW='\e[1;33m'
BLUE='\e[1;34m'
CYAN='\e[1;36m'
RESET='\e[0m'

set_varcolors() {
  # does the terminal support true-color?
  if [[ -n "$(command -v "tput")" ]]; then
    #tput setaf 127 | cat -v  #capturar saida
    : "${RED=$(tput bold)$(tput setaf 196)}"
    : "${GREEN=$(tput bold)$(tput setaf 2)}"
    : "${YELLOW=$(tput bold)$(tput setaf 3)}"
    : "${BLUE=$(tput setaf 4)}"
    : "${PURPLE=$(tput setaf 125)}"
    : "${CYAN=$(tput setaf 6)}"
    : "${NC=$(tput sgr0)}"
    : "${RESET=$(tput sgr0)}"
    : "${BOLD=$(tput bold)}"
    : "${black=$(tput bold)$(tput setaf 0)}"
    : "${reverse=$(tput rev)}"
    : "${branca=${black}$(tput setab 7)}"

    : "${reset=$(tput sgr0)}"
    : "${rst=$(tput sgr0)}"
    : "${bold=$(tput bold)}"
    : "${underline=$(tput smul)}"
    : "${nounderline=$(tput rmul)}"
    : "${reverse=$(tput rev)}"

    : "${black=$(tput bold)$(tput setaf 0)}"
    : "${red=$(tput bold)$(tput setaf 196)}"
    : "${green=$(tput bold)$(tput setaf 2)}"
    : "${yellow=$(tput bold)$(tput setaf 3)}"
    : "${blue=$(tput setaf 27)}"
    : "${pink=$(tput setaf 5)}"
    : "${magenta=$(tput setaf 5)}"
    : "${cyan=$(tput setaf 6)}"
    : "${white=$(tput setaf 7)}"
    : "${gray=$(tput setaf 8)}"
    : "${light_red=$(tput setaf 9)}"
    : "${light_green=$(tput setaf 10)}"
    : "${light_yellow=$(tput setaf 11)}"
    : "${light_blue=$(tput setaf 12)}"
    : "${light_magenta=$(tput setaf 13)}"
    : "${light_cyan=$(tput setaf 14)}"
    : "${light_white=$(tput setaf 15)}"
    : "${orange=$(tput setaf 202)}"
    : "${purple=$(tput setaf 125)}"
    : "${violet=$(tput setaf 61)}"

    # Definir cores de fundo
    : "${preto=$(tput setab 0)}"
    : "${vermelho=$(tput setab 196)}"
    : "${verde=$(tput setab 2)}"
    : "${amarelo=$(tput setab 3)}"
    : "${azul=$(tput setab 20)}"
    : "${roxo=$(tput setab 5)}"
    : "${ciano=$(tput setab 6)}"
    : "${branca="${black}$(tput setab 7)"}"
    : "${cinza=$(tput setab 8)}"
    : "${laranja=$(tput setab 202)}"
    : "${roxa=$(tput setab 125)}"
    : "${violeta=$(tput setab 61)}"

    : "${COL_NC='\e[0m'}" # No Color
    : "${COL_LIGHT_GREEN='\e[1;32m'}"
    : "${COL_LIGHT_RED='\e[1;31m'}"
    : "${DONE="${COL_LIGHT_GREEN} done!${COL_NC}"}"
    : "${OVER="\\r\\033[K"}"
    : "${DOTPREFIX="  ${black}::${reset} "}"
    : "${clrkey=${light_white}}"
    : "${TICK="${clrkey}[${green}✓✓✓${clrkey}]${rst}"}"
    : "${CROSS="${clrkey}[${red}✗✗✗${clrkey}]${rst}"}"
    : "${MID="${clrkey}[${red}✗✗${green}✓${clrkey}]${rst}"}"
    : "${WARN="${clrkey}[${yellow}⚠  ${clrkey}]${yellow}"}"
    : "${INFO="${clrkey}[${yellow}➡  ${clrkey}]${rst}"}"
  else
    unset_varcolors
  fi
}

msg()          { echo -e "${*}${reset}"; }
log_ok()       { echo -e "${TICK} ${*}${reset}"; }
log_err()      { echo -e "${CROSS} ${*}${reset}"; }
log_mid()      { echo -e "${MID} ${*}${reset}"; }
log_warn()     { echo -e "${WARN} ${*}${reset}"; }
msg_tab()      { echo -e "  ${INFO} ${*}${reset}"; }
log_ok_tab()   { echo -e "  ${TICK} ${*}${reset}"; }
log_err_tab()  { echo -e "  ${CROSS} ${*}${reset}"; }
log_mid_tab()  { echo -e "  ${MID} ${*}${reset}"; }
log_warn_tab() { echo -e "  ${WARN} ${*}${reset}"; }
die() {
  echo -e "${CROSS} ${red}${*}${reset}"
  exit 1
}

sh_checkroot() {
  (( EUID != 0 )) && elevate_to_root "$@" || return 0
}

elevate_to_root() {
  msg "This script must be run as root. Elevating privileges..."
  ccabec+='root [elevated]'
  # Tenta usar sudo primeiro (caso esteja configurado)
  if command -v sudo >/dev/null 2>&1; then
    exec sudo bash "$0" "$@"
  fi
  # Se sudo falhar, tenta su
  if command -v su >/dev/null 2>&1; then
    exec su -c "$0 $*"
  fi
  die "Error: Unable to elevate privileges. Run manually as root."
}

set_varcolors
sh_checkroot "$@"

[[ -d "$ISO_DIR" ]] || {
	msg "${red}Erro:${RESET} diretório não encontrado: ${yellow}$ISO_DIR${reset}"
	exit 1
}

voidbr_update_index_html() {
	[[ -f "$INDEX" ]] || {
		msg "${red}Erro:${reset} arquivo não encontrado: ${yellow}$INDEX${reset}"
		exit 1
	}

	cp -a "$INDEX" "$INDEX.bak"

	msg "${CYAN}==============================================${RESET}"
	msg "${CYAN}     Atualizador de links do index.html das ISOs VoidBR${RESET}"
	msg "${CYAN}==============================================${RESET}"

	update_iso() {
		local flavor="$1"
		local latest

		latest=$(
			find "$ISO_DIR" -maxdepth 1 \
				-name "voidbr-live-${flavor}-x86_64-*.iso" \
				-printf '%f\n' |
				sort -V |
				tail -n1
		)

		if [[ -z "$latest" ]]; then
			msg "${YELLOW}[SKIP]${RESET} ${flavor}: nenhuma ISO encontrada."
			return
		fi

		msg "${BLUE}[INFO]${RESET} ${flavor}: ${GREEN}${latest}${RESET}"

		sed -Ei \
			"s#iso/voidbr-live-${flavor}-x86_64-[^\"]*\.iso#iso/current/${latest}#g" \
			"$INDEX"
		sed -Ei \
			"s#iso/current/voidbr-live-${flavor}-x86_64-[^\"]*\.iso#iso/current/${latest}#g" \
			"$INDEX"

	}

	for flavor in \
		base \
		xfce \
		gnome \
		plasma \
		cinnamon \
		mate \
		sway \
		hyprland; do
		update_iso "$flavor"
	done

	msg ""
	msg "${GREEN}✔ ${INDEX} atualizado com sucesso.${RESET}"
	msg "${CYAN}Backup:${RESET} ${INDEX}.bak"
	msg "Feito!"
	echo
}

voidbr_update_iso_links() {
	local flavor latest link

	msg "${CYAN}==============================================${RESET}"
	msg "${CYAN}     Atualizador de links das ISOs VoidBR${RESET}"
	msg "${CYAN}==============================================${RESET}"

	for flavor in $(find "$ISO_DIR" -maxdepth 1 -name 'voidbr-live-*-x86_64-*.iso' |
		sed -E 's#.*/voidbr-live-([^-]+)-x86_64-.*#\1#' |
		sort -u); do

		latest=$(
			find "$ISO_DIR" -maxdepth 1 \
				-name "voidbr-live-${flavor}-x86_64-*.iso" \
				-printf '%f\n' |
				sort -V |
				tail -n1
		)

		[[ -n "$latest" ]] || continue

		link="voidbr-live-${flavor}-current.iso"

		ln -sfn "current/$latest" "$ISO_BASE_DIR/$link"
		msg "${BLUE}[LINK]${RESET} ${link} ${CYAN}->${RESET} ${GREEN}${latest}${RESET}"
	done
	msg "Feito!"
}

voidbr_archive_old_isos() {
	local flavor latest iso

	mkdir -p "$ISO_BASE_DIR/old"

	msg "${CYAN}==============================================${RESET}"
	msg "${CYAN}     Movendo ISOs antigas para ${ISO_BASE_DIR}/old/${RESET}"
	msg "${CYAN}==============================================${RESET}"

	for flavor in $(find "$ISO_BASE_DIR/current" -maxdepth 1 -name 'voidbr-live-*-x86_64-*.iso' |
		sed -E 's#.*/voidbr-live-([^-]+)-x86_64-.*#\1#' |
		sort -u); do

		latest=$(
			find "$ISO_BASE_DIR/current" -maxdepth 1 \
				-name "voidbr-live-${flavor}-x86_64-*.iso" \
				-printf '%f\n' |
				sort -V |
				tail -n1
		)

		[[ -n "$latest" ]] || continue

		while IFS= read -r iso; do
			iso="${iso##*/}"

			[[ "$iso" == "$latest" ]] && continue

			mv -f \
				"$ISO_BASE_DIR/current/$iso" \
				"$ISO_BASE_DIR/old/$iso"

			msg "${BLUE}[MOVE]${RESET} ${GREEN}${iso}${RESET} ${CYAN}->${RESET} old/"
		done < <(
			find "$ISO_BASE_DIR/current" -maxdepth 1 \
				-name "voidbr-live-${flavor}-x86_64-*.iso" \
				-printf '%f\n'
		)

	done

	msg "${GREEN}Feito!${RESET}"
}

voidbr_update_index_html
voidbr_update_iso_links
voidbr_archive_old_isos
