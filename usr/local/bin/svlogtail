export LANGUAGE="${LANGUAGE:-pt_BR}"
export TEXTDOMAINDIR=/usr/share/locale
export TEXTDOMAIN=svlogtail

sh_checkroot() {
	((EUID != 0)) && elevate_to_root "$@" || return 0
}

elevate_to_root() {
	echo "This script must be run as root. Elevating privileges..."
	if command -v sudo >/dev/null 2>&1; then
		exec sudo bash "$0" "$@"
	elif command -v su >/dev/null 2>&1; then
		exec su -c "$0 $*"
	fi
	echo "Unable to elevate privileges."
	exit 1
}

# -------- COLORIZADOR PROFISSIONAL --------
colorize() {
	awk '
    # Timestamp
    /^[0-9]{4}-[0-9]{2}-[0-9]{2}/ {
      printf "\033[90m%s\033[0m ", $1 " " $2
      sub(/^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2} /, "", $0)
    }

    # Kernel messages
    /kernel|kern/ && !/error|fail/ {
      print "\033[35m" $0 "\033[0m"
      next
    }

    # Auth / SSH
    /auth|sshd|pam/ {
      print "\033[31m" $0 "\033[0m"
      next
    }

    # Errors
    /ERROR|error|failed|FAIL|panic/ {
      print "\033[1;31m" $0 "\033[0m"
      next
    }

    # Warnings
    /WARN|Warn|warning/ {
      print "\033[33m" $0 "\033[0m"
      next
    }

    # Daemon/services
    /daemon/ {
      print "\033[32m" $0 "\033[0m"
      next
    }

    # Generic info
    /info|INFO/ {
      print "\033[36m" $0 "\033[0m"
      next
    }

/\[COMMAND\]/ {
    gsub(/\[COMMAND\]/, "\033[36m&\033[0m")

    gsub(/\bstart\b/,   "\033[32m&\033[0m")
    gsub(/\bstop\b/,    "\033[33m&\033[0m")
    gsub(/\brestart\b/, "\033[34m&\033[0m")
    gsub(/\breload\b/,  "\033[35m&\033[0m")

    print
    next
}

/\[REMOVE\]/ {
    gsub(/\[REMOVE\]/, "\033[31m&\033[0m")
    print
    next
}

/\[INSTALL\]/ {
    gsub(/\[INSTALL\]/, "\033[32m&\033[0m")
    print
    next
}

    # Default
    { print "\033[37m" $0 "\033[0m" }
  '
}

usage() {
	cat <<EOF
Usage: svlogtail [LOG...]

Examples:
  svlogtail
  svlogtail kernel
  svlogtail auth
  svlogtail daemon
  svlogtail messages
  svlogtail epoptes-client
  svlogtail nginx
EOF
}

LOGROOT="/var/log/socklog"

resolve_log() {
	case "$1" in
	/*)
		[ -e "$1" ] && printf '%s\n' "$1"
		;;
	*)
		[ -d "$LOGROOT/$1" ] && {
			printf '%s\n' "$LOGROOT/$1"
			return
		}

		[ -d "/var/log/$1" ] && {
			printf '%s\n' "/var/log/$1"
			return
		}

		find /var/log \
			-type f \
			-size +0c \
			-iname "*$1*" \
			! -path "/var/log/socklog/*" \
			2>/dev/null
		;;
	esac
}

sh_checkroot "$@"

case "$1" in
-h | --help)
	usage
	exit 0
	;;
esac

dirs=""
files=""

if [ $# -eq 0 ]; then
	dirs=$(find "$LOGROOT" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
else
	for arg in "$@"; do
		found=0
		while IFS= read -r p; do
			[ -z "$p" ] && continue
			if [ -d "$p" ]; then
				dirs="$dirs"$'\n'"$p"
				found=1
			elif [ -f "$p" ] && [ -s "$p" ]; then
				files="$files"$'\n'"$p"
				found=1
			fi
		done < <(resolve_log "$arg")

		[ $found -eq 1 ] || {
			printf "\033[1;33m[*]\033[0m no logs for '$arg'\n" >&2
			exit 1
		}
	done
fi

hist=()
follow=()

while IFS= read -r d; do
	[ -z "$d" ] && continue

	while IFS= read -r f; do
		[ -s "$f" ] || continue
		hist+=("$f")
		follow+=("$f")
	done < <(
		find "$d" \
			-maxdepth 1 \
			-type f \
			-size +0c \
			\( \
			-name current -o \
			-name "*.log" -o \
			-name "*.out" -o \
			-name "*.[us]" \
			\) \
			2>/dev/null
	)

done <<<"$dirs"

if [ $# -eq 0 ]; then
	while IFS= read -r f; do
		[ -s "$f" ] || continue
		hist+=("$f")
		follow+=("$f")
	done < <(
		find /var/log \
			-type f \
			-size +0c \
			\( \
			-name current -o \
			-name "*.log" -o \
			-name "*.out" \
			\) \
			! -path "/var/log/socklog/*" \
			2>/dev/null
	)
else
	while IFS= read -r f; do
		[ -s "$f" ] || continue
		hist+=("$f")
		follow+=("$f")
	done <<<"$files"
fi

if [ -z "$hist" ]; then
	printf "\033[1;33m[*]\033[0m log is empty '$1'\n"
	exit 0
fi

if ((${#hist[@]})); then
	cat "${hist[@]}" 2>/dev/null | sort | colorize
fi

if ((${#follow[@]})); then
	exec tail -Fq -n0 "${follow[@]}" | colorize
fi

exit 0
