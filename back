sh_alternar_backend() {
	local novo_backend="$1"

	if [[ "$novo_backend" == "NetworkManager" ]]; then
		# 1. Para o serviço iwd
		sv down iwd

		# 2. Identifica o driver da placa
		local driver_path="/sys/class/net/$iface/device/driver"
		local driver_name=$(basename "$(readlink "$driver_path")")

		# 3. Identifica o dependente real (o "filho")
		# Agora veremos erros caso o 'ls' ou 'head' falhem
		local filho=$(ls -1 /sys/module/"$driver_name"/holders | head -n 1)

		# 4. Executa o reset do módulo
		if [[ -n "$filho" ]]; then
			echo "Reiniciando módulo: $filho"
			modprobe -r "$filho"
			sleep 1
			modprobe "$filho"
			sleep 3
		else
			echo "Erro: Nenhum módulo dependente encontrado para $driver_name"
		fi

		# 5. Inicia o NetworkManager
		sv up NetworkManager
	fi
}

sv start iwd
iface=wlo1
sh_alternar_backend "NetworkManager"
