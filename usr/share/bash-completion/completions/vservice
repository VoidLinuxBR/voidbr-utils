# bash completion for vservice

_vservice_enabled_services() {
    local s

    for s in /var/service/*; do
        [[ -e "$s" ]] || continue
        basename "$s"
    done
}

_vservice_available_services() {
    local s

    for s in /etc/sv/*; do
        [[ -e "$s" ]] || continue

        # Não lista serviços já habilitados
        [[ -e "/var/service/$(basename "$s")" ]] && continue

        basename "$s"
    done
}

_vservice_completion() {
    local cur prev opts services

    COMPREPLY=()

    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    opts="add enable install disable remove rm start st up stop down restart reload status list once pause exit"

    # Primeiro argumento: comandos
    if [[ $COMP_CWORD -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
        return 0
    fi

    case "$prev" in
        add|enable|install)
            services="$(_vservice_available_services)"
            ;;
        disable|remove|rm|start|st|up|stop|down|restart|reload|status|once|pause|exit)
            services="$(_vservice_enabled_services)"
            ;;
        *)
            return 0
            ;;
    esac

    COMPREPLY=( $(compgen -W "$services" -- "$cur") )
}

complete -F _vservice_completion vservice
