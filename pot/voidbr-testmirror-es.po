msgstr "Error al instalar los comandos. Pruebe manualmente."

#: usr/local/bin/voidbr-testmirror:715
msgid "Erro: você não pode realizar esta operação a menos que seja root."
msgstr "error: no puedes realizar esta operación a menos que seas root."

